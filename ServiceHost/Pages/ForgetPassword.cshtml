@page
@model ServiceHost.Pages.ForgetPasswordModel
@{
    ViewData["Title"] = "بازیابی کلمه عبور";
}

<div class="page-content-area">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="page-wrapper">
                    <div class="page-content-wrapper">
                        <div class="row">
                            <div class="col-sm-12 col-md-12 col-xs-12 col-lg-6 m-auto">
                                @if (!string.IsNullOrWhiteSpace(Model.Message))
                                {
                                    <div class="alert alert-danger">@Model.Message</div>
                                }
                                <form method="post">
                                    <div class="login-form">
                                        <div class="row">
                                            <div class="col-md-12 col-12">
                                                <label for="nationalCode">کد ملی</label>
                                                <input name="nationalCode" id="nationalCode" class="form-control" type="text" maxlength="10" placeholder="کد ملی خود را وارد کنید" autofocus>
                                            </div>
                                            <div class="col-md-12 col-12 text-center">
                                                <button type="submit" class="btn btn-warning w-100">ارسال رمز یکبار مصرف</button>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

